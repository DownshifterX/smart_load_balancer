# NEXUS // Environment Template
# Copy this file to .env and fill in your real credentials.
# DO NOT PUBLISH YOUR ACTUAL .ENV FILE TO GITHUB.

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Simulation Defaults
SIMULATION_TICK_MS=500
MAX_SERVERS=20
DEFAULT_ALGORITHM=round_robin
DEFAULT_TRAFFIC_MODE=normal

# Email API Settings (Resend - HTTP Delivery)
# Create a free account at resend.com to get an API key
RESEND_API_KEY=re_YOUR_KEY_HERE
