# NEXUS // Environment Template
# Copy this file to .env and fill in your real credentials.
# DO NOT PUBLISH YOUR ACTUAL .ENV FILE TO GITHUB.

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Simulation Defaults
SIMULATION_TICK_MS=500
MAX_SERVERS=20
DEFAULT_ALGORITHM=round_robin
DEFAULT_TRAFFIC_MODE=normal

# SMTP Configuration (Gmail Example)
# Get an APP PASSWORD from: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_TLS=True
