      "weight": 1,
      "max_connections": 120,
      "response_time_base": 55
    },
    {
      "name": "NODE-GAMMA",
      "weight": 2,
      "max_connections": 150,
      "response_time_base": 40
    },
    {
      "name": "NODE-DELTA",
      "weight": 1,
      "max_connections": 80,
      "response_time_base": 60
