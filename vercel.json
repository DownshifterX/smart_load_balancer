{
  "version": 2,
  "name": "nexus-frontend",
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|assets)/(.*)",
      "dest": "/frontend/$1/$2"
    },
    {
      "src": "/ws",
      "status": 404,
      "statusText": "WebSockets not supported on Vercel Serverless. Use the Render backend."
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
